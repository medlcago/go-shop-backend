APP_NAME=go-shop-backend
ENVIRONMENT=development
AUTH_SECRET=secret
AUTH_ACCESS_TOKEN_EXPIRED_TIME=30m
AUTH_REFRESH_TOKEN_EXPIRED_TIME=43200m
AUTH_PARTIAL_TOKEN_EXPIRED_TIME=5m
SHUTDOWN_TIMEOUT=30s
ORDER_CANCEL_DELAY=10m
MASTER_KEY=cG9zaXRpb251cHBlcmNvb2thcnJhbmdlcG9vcnJvYWQ=

HTTP_SERVER_PORT=8080
HTTP_SERVER_READ_TIMEOUT=10s
HTTP_SERVER_WRITE_TIMEOUT=10s
HTTP_SERVER_IDLE_TIMEOUT=30s

GOOSE_DRIVER=postgres
GOOSE_DBSTRING=postgres://postgres:postgres@localhost:5432/go-shop-backend?sslmode=disable
GOOSE_MIGRATION_DIR=./migrations
GOOSE_TABLE=goose_migrations

DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=go-shop-backend
DB_URI=postgres://postgres:postgres@localhost:5432/go-shop-backend?sslmode=disable
DB_MAX_OPEN_CONNS=100
DB_MAX_IDLE_CONNS=50
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m
DB_DIALECT=postgres
DB_AUTO_MIGRATE=true

REDIS_ADDRESS=127.0.0.1:6379
REDIS_PASSWORD=secretpassword
REDIS_DB=0
REDIS_DIAL_TIMEOUT=5s
REDIS_READ_TIMEOUT=3s
REDIS_WRITE_TIMEOUT=3s
REDIS_POOL_SIZE=10
REDIS_MIN_IDLE_CONNS=5

CORS_ALLOW_METHODS='GET, POST, PUT, PATCH, DELETE, OPTIONS'
CORS_ALLOW_ORIGINS='http://localhost:8080, http://127.0.0.1:8080'
CORS_ALLOW_HEADERS='Authorization, Content-Type, Origin, Accept, X-Requested-With, X-Session-ID'
CORS_EXPOSE_HEADERS=Authorization
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400
CORS_ALLOW_PRIVATE_NETWORK=false

S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_USE_SSL=false
S3_BASE_URL=http://localhost:9000
S3_BUCKET=media
S3_REGION=us-east-1

UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_PRESIGNED_URL_TTL=20m

YOOKASSA_ACCOUNT_ID=123
YOOKASSA_SECRET_KEY=test
YOOKASSA_RETURN_URL=https://www.google.com/

EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USERNAME=example@gmail.com
EMAIL_PASSWORD=password
EMAIL_FROM=example@gmail.com
EMAIL_CONFIRMATION_CODE_LENGTH=6
EMAIL_CONFIRMATION_CODE_TTL=2m